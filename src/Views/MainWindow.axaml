<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AIMediaPlayer.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="AIMediaPlayer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AI Media Player"
        Width="1000" Height="550"
        Icon="/Assets/logo.ico">

    <Window.Styles>
        <Style Selector="Button#PlayPauseButton">
            <Setter Property="Background" Value="#00C853" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button#PlayPauseButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button#PlayPauseButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#44FFFFFF"/>
        </Style>
    </Window.Styles>

    <Grid Name="InputLayer" Background="Transparent" IsHitTestVisible="True">

        <vlc:VideoView Name="VideoPlayer"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch">

            <Grid>

                <Grid Name="VideoOverlay" Background="Transparent" IsHitTestVisible="True" />

                <Border Name="ControlBar"
                        Background="#2b2b2b"
                        Padding="15,10"
                        VerticalAlignment="Bottom"
                        Opacity="1">

                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.4"/>
                        </Transitions>
                    </Border.Transitions>

                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, 250">
                        <ListBox Name="PlaylistBox"
                                 Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                 Background="#333333" Foreground="White"
                                 Margin="10,0,0,0">
                        </ListBox>

                        <Slider Name="ProgressSlider"
                                Grid.Row="0" Grid.Column="0"
                                Minimum="0" Maximum="1"
                                Margin="0,0,0,10"/>

                        <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="Auto, *, Auto">
                            <Button Grid.Column="0" Content="Open file"
                                    Command="{Binding OpenFileCommand}"
                                    CommandParameter="{Binding $parent[Window].StorageProvider}"
                                    Padding="10,5"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center" Spacing="10">
                                <Button Name="PrevButton" Content="⏮" Click="Prev_OnClick" FontSize="20"/>
                                <Button Name="PlayPauseButton" Content="▶" Click="PlayPause_OnClick"
                                        Width="65" FontSize="20" HorizontalContentAlignment="Center"/>
                                <Button Name="NextButton" Content="⏭" Click="Next_OnClick" FontSize="20"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="🔊" VerticalAlignment="Center" Foreground="White"/>
                                <Slider Name="VolumeSlider" Width="100" Minimum="0" Maximum="100" Value="100"
                                        PropertyChanged="VolumeSlider_PropertyChanged" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </vlc:VideoView>

    </Grid>
</Window>
